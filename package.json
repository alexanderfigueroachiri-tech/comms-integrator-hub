{
  "name": "comms-integrator-hub",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @cih/web dev",
    "build": "pnpm --filter @cih/web build",
    "lint": "pnpm --filter @cih/web lint",
    "test": "pnpm --filter @cih/shared test",
    "db:generate": "pnpm --filter @cih/database db:generate",
    "db:push": "pnpm --filter @cih/database db:push",
    "db:seed": "pnpm --filter @cih/database db:seed",
    "db:studio": "pnpm --filter @cih/database db:studio",
    "db:up": "docker compose up -d postgres"
  },
  "packageManager": "pnpm@9.15.0"
}
